{
  "manifest_version": 3,
  "name": "Zappo",
  "version": "1.0.0",
  "description": "Intelligent web data collection, enrichment, and export.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "notifications"
  ],
  "key": "",
  "host_permissions": [
    "https://*/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "file:///*",
    "https://techcrunch.com/*",
    "https://feeds.arstechnica.com/*",
    "https://www.wired.com/*",
    "https://www.theverge.com/*",
    "https://news.crunchbase.com/*",
    "https://www.sciencedaily.com/*",
    "https://phys.org/*",
    "https://feeds.bbci.co.uk/*",
    "https://www.reuters.com/*",
    "https://rss.nytimes.com/*",
    "https://stackoverflow.com/*",
    "https://feeds.feedburner.com/*",
    "https://krebsonsecurity.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-magic-bar.js",
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "toggle-magic-bar": {
      "suggested_key": {
        "default": "Ctrl+Z",
        "mac": "Command+Z"
      },
      "description": "Toggle Magic Extract Bar"
    }
  },
  "web_accessible_resources": [],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}